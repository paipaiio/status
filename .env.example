# Server
PORT=3010
HOST=127.0.0.1
FRONTEND_ORIGIN=http://127.0.0.1:3010

# Scheduler
CHECK_INTERVAL_SECONDS=60
REQUEST_TIMEOUT_MS=12000
HISTORY_LIMIT=24
STATUS_HISTORY_FILE=runtime/status-history.json
STATUS_HISTORY_RETENTION_DAYS=30
STATUS_HISTORY_LIMIT=50000
ANNOTATIONS_FILE=runtime/annotations.json
ANNOTATION_API_TOKEN=change-me-integration-token
NOTIFICATION_WEBHOOK_URLS=
NOTIFICATION_WEBHOOK_TOKEN=
NOTIFICATION_TIMEOUT_MS=5000

# Optional: enables POST /api/check from the dashboard.
# Keep this private and rotate it if shared accidentally.
MANUAL_CHECK_TOKEN=change-me-before-use

# Admin console at /admin. Change these before exposing a public site.
ADMIN_USERNAME=root
ADMIN_PASSWORD=Admin@123
ADMIN_SESSION_TTL_HOURS=24
MANAGED_TARGETS_FILE=config/targets.json

# Optional QQ group bot bridge. Use with NapCat OneBot reverse WebSocket.
QQ_BOT_HOST=172.17.0.1
QQ_BOT_PORT=3211
QQ_BOT_PATH=/onebot
QQ_BOT_TRIGGER=状态检查
QQ_BOT_COOLDOWN_MS=30000
ONEBOT_SHARED_TOKEN=
STATUS_PAGE_URL=https://status.example.com/?capture=qq
CHROMIUM_BIN=/usr/bin/chromium
STATUS_SCREENSHOT_WIDTH=1080
STATUS_SCREENSHOT_HEIGHT=1280
STATUS_SCREENSHOT_WAIT_MS=4500
STATUS_CAPTURE_PER_PAGE=4
STATUS_CAPTURE_MAX_PAGES=8
STATUS_CAPTURE_WINDOW=90m

# Add one group for each API relay you want to monitor.
# BASE_URL can be a host or a full https://.../v1 base URL.
# FORMAT can be auto, openai, or anthropic.
# CHECK_MODE=auto tries model-list first, then max_tokens=1 only if needed.
API_1_NAME=主用中转站
API_1_BASE_URL=api.example.com
API_1_MODEL=gpt-4o-mini
API_1_API_KEY=sk-your-real-key
API_1_FORMAT=auto
API_1_CHECK_MODE=auto

# Optional second group with Anthropic-style headers and /v1/messages.
API_2_NAME=备用中转站
API_2_BASE_URL=https://backup.example.com/v1
API_2_MODEL=claude-3-5-haiku-latest
API_2_API_KEY=sk-your-backup-key
API_2_FORMAT=anthropic
API_2_CHECK_MODE=auto
